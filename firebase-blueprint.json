{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "sku", "price", "stock", "category", "ownerId", "createdAt", "updatedAt"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A recorded sale transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "timestamp": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "card", "pix"] },
        "discount": { "type": "number" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "items", "total", "timestamp", "paymentMethod", "discount", "ownerId"]
    },
    "StoreConfig": {
      "title": "StoreConfig",
      "description": "Store configuration settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "subtitle": { "type": "string" },
        "cnpj": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "footerMessage": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "subtitle", "cnpj", "address", "phone", "footerMessage", "ownerId"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of sales"
    },
    "/settings/{ownerId}": {
      "schema": "StoreConfig",
      "description": "Store configuration per owner"
    }
  }
}
