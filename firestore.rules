rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'sku', 'price', 'stock', 'category', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 9 &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.sku is string && data.sku.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.stock is number &&
             data.category is string && data.category.size() <= 100;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['id', 'items', 'total', 'timestamp', 'paymentMethod', 'discount']) &&
             data.id is string && data.id.size() <= 128 &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.paymentMethod in ['cash', 'card', 'pix'] &&
             data.discount is number && data.discount >= 0 &&
             (!data.keys().contains('notes') || (data.notes is string && data.notes.size() <= 1000));
    }

    function isValidStoreConfig(data) {
      return data.keys().hasAll(['name', 'subtitle', 'cnpj', 'address', 'phone', 'footerMessage']) &&
             data.name is string && data.name.size() <= 200 &&
             data.subtitle is string && data.subtitle.size() <= 200 &&
             data.cnpj is string && data.cnpj.size() <= 20 &&
             data.address is string && data.address.size() <= 500 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.footerMessage is string && data.footerMessage.size() <= 500;
    }

    // --- Rules for users ---

    match /users/{userId} {
      // Products
      match /products/{productId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(productId);
        allow create: if isOwner(userId) && isValidId(productId) && isValidProduct(incoming());
        allow update: if isOwner(userId) && isValidId(productId) && isValidProduct(incoming());
        allow delete: if isOwner(userId) && isValidId(productId);
      }

      // Sales
      match /sales/{saleId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(saleId);
        allow create: if isOwner(userId) && isValidId(saleId) && isValidSale(incoming());
        allow update: if false; // Sales should be immutable
        allow delete: if false; // Or restricted
      }

      // Config
      match /config/{configId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && (configId == 'main') && isValidStoreConfig(incoming());
      }
    }
  }
}
