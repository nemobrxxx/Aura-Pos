rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'sku', 'price', 'stock', 'category', 'ownerId', 'createdAt', 'updatedAt'])
        && data.keys().size() == 9
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.sku is string && data.sku.size() <= 50
        && data.price is number && data.price >= 0
        && data.stock is number
        && data.category is string && data.category.size() <= 100
        && data.ownerId == request.auth.uid;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['id', 'items', 'total', 'timestamp', 'paymentMethod', 'discount', 'ownerId'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 128
        && data.items is list && data.items.size() > 0 && data.items.size() <= 100
        && data.total is number && data.total >= 0
        && data.paymentMethod in ['cash', 'card', 'pix']
        && data.discount is number && data.discount >= 0
        && data.ownerId == request.auth.uid;
    }

    function isValidStoreConfig(data) {
      return data.keys().hasAll(['name', 'subtitle', 'cnpj', 'address', 'phone', 'footerMessage', 'ownerId', 'updatedAt'])
        && data.keys().size() == 8
        && data.name is string && data.name.size() <= 100
        && data.subtitle is string && data.subtitle.size() <= 100
        && data.cnpj is string && data.cnpj.size() <= 25
        && data.address is string && data.address.size() <= 300
        && data.phone is string && data.phone.size() <= 20
        && data.footerMessage is string && data.footerMessage.size() <= 500
        && data.ownerId == request.auth.uid;
    }

    // --- Collections ---

    match /products/{productId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(productId)
        && isValidProduct(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn()
        && isValidId(productId)
        && isValidProduct(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().ownerId == existing().ownerId;

      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /sales/{saleId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      
      allow create: if isSignedIn()
        && isValidId(saleId)
        && isValidSale(incoming())
        && incoming().timestamp == request.time;

      allow update, delete: if false; // Sales are immutable records
    }

    match /settings/{ownerId} {
      allow read: if isSignedIn() && ownerId == request.auth.uid;
      
      allow write: if isSignedIn()
        && ownerId == request.auth.uid
        && isValidStoreConfig(incoming())
        && incoming().updatedAt == request.time;
    }
  }
}
